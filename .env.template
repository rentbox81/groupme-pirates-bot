# GroupMe Bot Configuration Template
# Copy this to .env and fill in your values

# GroupMe Bot Settings
GROUPME_BOT_ID=your_groupme_bot_id_here
GROUPME_BOT_NAME=YourBotName
# Bot name should match team (e.g., PirateBot, DragonflyBot, etc.)

# Google Sheets Configuration
SHEET_ID=your_google_sheet_id_here
GOOGLE_API_KEY=your_google_api_key_here

# Calendar Configuration
CALENDAR_WEBCAL_URL=your_webcal_url_here
# Optional: Legacy Google Calendar ID (if not using webcal)
#CALENDAR_ID=your_google_calendar_id_here

# Domain Configuration
# Team name (lowercase, used for subdomain)
TEAM_NAME=yourteam
# Examples:
#   pirates -> piratesbot.yourdomain.com
#   dragons -> dragonsbot.yourdomain.com
#   eagles -> eaglesbot.yourdomain.com
#   lions -> lionsbot.yourdomain.com

# Base domain (your registered domain)
BASE_DOMAIN=yourdomain.com
# Examples:
#   rentbox.us
#   myteambot.com
#   sportsbots.net

# Traefik Configuration
CERT_RESOLVER=letsencrypt
TRAEFIK_NETWORK=traefik

# Server Configuration (optional)
PORT=18080
RUST_LOG=info

# The final URL will be: https://{TEAM_NAME}bot.{BASE_DOMAIN}
# Examples:
#   https://piratesbot.rentbox.us
#   https://dragonsbot.rentbox.us
#   https://eaglesbot.myteambot.com

# Reminder Configuration (optional, defaults: 9am - 9pm)
# Hours are in 24-hour format (0-23)
REMINDER_START_HOUR=9
REMINDER_END_HOUR=21
